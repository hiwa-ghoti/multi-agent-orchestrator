{
  "name": "multi-agent-orchestrator",
  "version": "0.1.0",
  "description": "CLI orchestrator that runs multiple Cursor agents in parallel or keeps one agent looping autonomously",
  "type": "module",
  "bin": {
    "agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "agent": "tsx src/index.ts",
    "ui": "tsx src/ui/server.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cursor",
    "agent",
    "orchestrator",
    "multi-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
